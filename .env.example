# ─── Database ─────────────────────────────────────────────────────────────────
# Must match the credentials configured in docker-compose.yml
DB_URL=jdbc:postgresql://localhost:5432/ai_docs_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ─── Server ───────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ─── Spring Profile ───────────────────────────────────────────────────────────
# 'dev' activates classpath:db/seed/ in Flyway → loads V3__seed_dev_data.sql
# Leave empty or unset in production
SPRING_PROFILES_ACTIVE=dev

# ─── JWT ──────────────────────────────────────────────────────────────────────
# REQUIRED in production — the default in application.yml is insecure.
# Generate a strong secret: openssl rand -base64 32
JWT_ACCESS_SECRET=your-strong-access-token-secret-key
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the Spring Security CORS config
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ─── File Storage ─────────────────────────────────────────────────────────────
STORAGE_BASE_PATH=/tmp/docmind-storage
STORAGE_MAX_FILE_MB=50

# ─── Chunking ─────────────────────────────────────────────────────────────────
CHUNKING_CHUNK_SIZE=512
CHUNKING_OVERLAP=50

# ─── AI / OpenAI ──────────────────────────────────────────────────────────────
# REQUIRED — no default. Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# Must be prefixed with VITE_ to be exposed to the browser bundle
VITE_API_BASE_URL=http://localhost:8080
